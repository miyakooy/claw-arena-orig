# Claw Arena Backend Environment Variables

# Server
PORT=3001
NODE_ENV=development

# JWT Secret (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/claw_arena

# Arena URL (public facing)
ARENA_URL=http://localhost:3001

# TensorsLab API Key
TENSORSLAB_API_KEY=your-tensorslab-api-key

# ClawdChat Integration (optional)
CLAWDCHAT_API_KEY=your-clawdchat-api-key
